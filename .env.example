# ─────────────────────────────────────────────────────────────────────────────
# Beba SACCO Frontend – Environment Variables
#
# Copy this file to .env.local for local development.
# For production (Netlify), set these in the Netlify dashboard:
#   Site → Configuration → Environment variables
#
# NEXT_PUBLIC_* variables are embedded at build time and visible to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash, must end with /api/v1)
# Local dev:   http://localhost:3001/api/v1
# Production:  https://your-render-service.onrender.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Default tenant UUID — sent as X-Tenant-ID header on every API request.
# Find this value by running: node backend/check_super_admin.js
# Or query: SELECT id FROM "Tenant" WHERE slug = 'beba-demo';
NEXT_PUBLIC_TENANT_ID=your-tenant-uuid-here

# Origin the browser PUTs document/profile-image uploads to directly
# (the presigned R2 URL host — must match backend's R2_ACCOUNT_ID). Needed
# in the CSP connect-src allow-list or uploads are blocked client-side.
# Local dev (MinIO):  http://localhost:9000
# Production:         https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
NEXT_PUBLIC_UPLOAD_ORIGIN=https://your-r2-account-id.r2.cloudflarestorage.com

# Support-chat WebSocket base URL (optional). The chat gateway rides on the
# same server as the REST API, so this defaults to NEXT_PUBLIC_API_URL's
# origin with ws(s):// substituted for http(s)://. Only set this if the
# socket.io gateway is ever split onto a different host/port.
# NEXT_PUBLIC_BACKEND_WS_URL=wss://your-render-service.onrender.com

# ── Cypress E2E tests (optional) ──────────────────────────────────────────────
# Override tenant ID for test environment
# CYPRESS_TENANT_ID=your-test-tenant-uuid
